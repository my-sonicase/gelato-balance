# ── Database ────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (URI mode)
# Use the "Transaction" pooler URL (port 6543) for serverless/edge, or the
# direct connection (port 5432) for this long-running Express server.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Auth / Sessions ──────────────────────────────────────────────────────────
# Any long random string — used to sign JWT tokens AND encrypt session cookies.
# Generate one with: openssl rand -hex 64
SESSION_SECRET=replace_me_with_a_long_random_string

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Admin seed (optional — only used on first boot if no users exist) ────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_after_first_login
